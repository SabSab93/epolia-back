NODE_ENV=development
PORT=3000

# Local PostgreSQL Docker database.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/epolia?schema=public"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5433/epolia?schema=public"

# Supabase note:
# - DATABASE_URL can use the pooled connection URL.
# - DIRECT_URL must use the direct connection URL for migrations.

CORS_ORIGIN=http://localhost:3000,http://localhost:8081
